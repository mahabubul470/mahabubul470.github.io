---
import { site } from "../data/site";
import ThemeToggle from "./ThemeToggle.astro";

const links = [
  { label: "Projects", href: "#projects" },
  { label: "Experience", href: "#experience" },
  { label: "Research", href: "#research" },
  { label: "About", href: "#about" },
];
---

<header
  class="fixed inset-x-0 top-0 z-40 border-b border-transparent backdrop-blur transition-colors data-[scrolled=true]:border-zinc-200/80 data-[scrolled=true]:bg-white/80 dark:data-[scrolled=true]:border-zinc-800/80 dark:data-[scrolled=true]:bg-zinc-950/80"
  id="site-header"
>
  <nav class="mx-auto flex h-16 max-w-5xl items-center justify-between px-5 sm:px-6">
    <a
      href="#top"
      class="font-mono text-sm font-semibold tracking-tight text-zinc-900 dark:text-zinc-100"
    >
      {site.initials}<span class="text-accent-500">.</span>
    </a>

    <div class="flex items-center gap-1 sm:gap-2">
      <ul class="mr-1 hidden items-center gap-1 sm:flex">
        {links.map((l) => (
          <li>
            <a
              href={l.href}
              class="rounded-md px-3 py-2 text-sm text-zinc-600 transition hover:text-accent-600 dark:text-zinc-400 dark:hover:text-accent-400"
            >
              {l.label}
            </a>
          </li>
        ))}
      </ul>
      <a
        href={site.resumes.professional}
        target="_blank"
        rel="noopener"
        class="hidden rounded-lg bg-zinc-900 px-3.5 py-2 text-sm font-medium text-white transition hover:bg-accent-600 sm:inline-block dark:bg-zinc-100 dark:text-zinc-900 dark:hover:bg-accent-400"
      >
        Résumé
      </a>
      <ThemeToggle />
    </div>
  </nav>
</header>

<script is:inline>
  (() => {
    const header = document.getElementById("site-header");
    if (!header) return;
    const onScroll = () =>
      header.setAttribute("data-scrolled", String(window.scrollY > 8));
    onScroll();
    window.addEventListener("scroll", onScroll, { passive: true });
  })();
</script>
