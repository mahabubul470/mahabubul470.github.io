---
interface Props {
  eyebrow: string;
  title: string;
  lead?: string;
}
const { eyebrow, title, lead } = Astro.props;
---

<div class="reveal mb-10 max-w-2xl">
  <p class="font-mono text-xs font-medium uppercase tracking-widest text-accent-600 dark:text-accent-400">
    {eyebrow}
  </p>
  <h2 class="mt-2 text-2xl font-bold tracking-tight text-zinc-900 sm:text-3xl dark:text-zinc-50">
    {title}
  </h2>
  {lead && <p class="mt-3 text-base leading-relaxed text-zinc-600 dark:text-zinc-400">{lead}</p>}
</div>
