---
import { research, publication, researchInterests } from "../data/research";
import SectionHeading from "./SectionHeading.astro";
import Icon from "./Icon.astro";
---

<section id="research" class="mx-auto max-w-5xl px-5 py-20 sm:px-6">
  <SectionHeading
    eyebrow="Research"
    title="Applied ML & computer vision"
    lead="Alongside engineering, I work on computer-vision and deep-learning research — from biometric recognition to autonomous navigation."
  />

  <div class="reveal mb-4 flex flex-wrap gap-2">
    {researchInterests.map((i) => (
      <span class="rounded-full border border-accent-500/30 bg-accent-500/5 px-3 py-1 text-xs font-medium text-accent-700 dark:text-accent-300">
        {i}
      </span>
    ))}
  </div>

  <!-- Publication -->
  <a
    href={publication.doiUrl}
    target="_blank"
    rel="noopener"
    class="reveal group mb-8 block rounded-2xl border border-zinc-200 bg-white p-6 transition hover:border-accent-400 dark:border-zinc-800 dark:bg-zinc-900/40 dark:hover:border-accent-500/60"
  >
    <div class="flex items-center justify-between gap-3">
      <span class="font-mono text-xs font-medium uppercase tracking-widest text-accent-600 dark:text-accent-400">
        Publication · IEEE
      </span>
      <Icon name="external" class="h-4 w-4 text-zinc-400 transition group-hover:text-accent-500" />
    </div>
    <h3 class="mt-2 text-base font-semibold text-zinc-900 dark:text-zinc-100">
      {publication.title}
    </h3>
    <p class="mt-1 text-sm text-zinc-600 dark:text-zinc-400">{publication.authors}</p>
    <p class="mt-1 text-sm italic text-zinc-500 dark:text-zinc-500">{publication.venue}</p>
    <p class="mt-2 font-mono text-xs text-zinc-500 dark:text-zinc-500">DOI: {publication.doi}</p>
  </a>

  <!-- Research projects -->
  <div class="grid gap-6 md:grid-cols-3">
    {research.map((r) => (
      <article class="reveal flex flex-col rounded-2xl border border-zinc-200 bg-white p-5 dark:border-zinc-800 dark:bg-zinc-900/40">
        <h3 class="text-sm font-semibold leading-snug text-zinc-900 dark:text-zinc-100">
          {r.title}
        </h3>
        <p class="mt-1 text-xs text-accent-600 dark:text-accent-400">{r.role}</p>
        <p class="mt-0.5 font-mono text-xs text-zinc-500 dark:text-zinc-500">{r.period}</p>
        <ul class="mt-3 flex-1 space-y-2">
          {r.points.map((pt) => (
            <li class="flex gap-2 text-xs leading-relaxed text-zinc-600 dark:text-zinc-400">
              <span class="mt-1.5 h-1 w-1 shrink-0 rounded-full bg-accent-500"></span>
              {pt}
            </li>
          ))}
        </ul>
        <ul class="mt-4 flex flex-wrap gap-1.5">
          {r.tech.map((t) => (
            <li class="rounded bg-zinc-100 px-1.5 py-0.5 font-mono text-[11px] text-zinc-600 dark:bg-zinc-800 dark:text-zinc-400">
              {t}
            </li>
          ))}
        </ul>
      </article>
    ))}
  </div>
</section>
