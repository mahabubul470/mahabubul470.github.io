---
import { projects } from "../data/projects";
import SectionHeading from "./SectionHeading.astro";
import Icon from "./Icon.astro";

const featured = projects.filter((p) => p.featured);
---

<section id="projects" class="mx-auto max-w-5xl px-5 py-20 sm:px-6">
  <SectionHeading
    eyebrow="Selected work"
    title="Projects I'm proud of"
    lead="A real-time database library, a carbon-aware cloud optimizer, an AI-native VCS, and a production payment gateway. The deep ones, not the demos."
  />

  <div class="grid gap-6 md:grid-cols-2">
    {featured.map((p) => (
      <article
        class="reveal group flex flex-col rounded-2xl border border-zinc-200 bg-white p-6 transition hover:border-accent-400 hover:shadow-lg hover:shadow-accent-500/5 dark:border-zinc-800 dark:bg-zinc-900/40 dark:hover:border-accent-500/60"
      >
        <div class="flex items-start justify-between gap-4">
          <div>
            <h3 class="text-lg font-semibold text-zinc-900 dark:text-zinc-100">
              {p.name}
            </h3>
            <p class="mt-0.5 font-mono text-xs text-zinc-500 dark:text-zinc-500">{p.tag}</p>
          </div>
          <div class="flex shrink-0 gap-1.5">
            {p.links.map((l) => (
              <a
                href={l.href}
                target="_blank"
                rel="noopener"
                aria-label={`${p.name} — ${l.label}`}
                class="inline-flex items-center gap-1 rounded-md border border-zinc-200 px-2 py-1 text-xs text-zinc-600 transition hover:border-accent-400 hover:text-accent-600 dark:border-zinc-700 dark:text-zinc-400 dark:hover:text-accent-400"
              >
                {l.label === "npm" ? <Icon name="npm" class="h-3.5 w-3.5" /> : l.label === "GitHub" ? <Icon name="github" class="h-3.5 w-3.5" /> : null}
                {l.label}
              </a>
            ))}
          </div>
        </div>

        <p class="mt-4 text-sm leading-relaxed text-zinc-600 dark:text-zinc-400">
          {p.blurb}
        </p>

        {p.stat && (
          <div class="mt-4 rounded-lg bg-accent-500/5 px-4 py-3 dark:bg-accent-500/10">
            <span class="font-mono text-lg font-semibold text-accent-700 dark:text-accent-300">
              {p.stat.value}
            </span>
            <span class="ml-2 text-xs text-zinc-500 dark:text-zinc-400">{p.stat.label}</span>
          </div>
        )}

        <ul class="mt-4 space-y-2">
          {p.highlights.map((h) => (
            <li class="flex gap-2.5 text-sm leading-relaxed text-zinc-600 dark:text-zinc-400">
              <span class="mt-2 h-1 w-1 shrink-0 rounded-full bg-accent-500"></span>
              {h}
            </li>
          ))}
        </ul>

        <ul class="mt-5 flex flex-wrap gap-1.5 pt-1">
          {p.tech.map((t) => (
            <li class="rounded-md bg-zinc-100 px-2 py-1 font-mono text-xs text-zinc-600 dark:bg-zinc-800 dark:text-zinc-400">
              {t}
            </li>
          ))}
        </ul>
      </article>
    ))}
  </div>

  <div class="reveal mt-8 text-center">
    <a
      href="https://github.com/mahabubul470"
      target="_blank"
      rel="noopener"
      class="inline-flex items-center gap-2 text-sm font-medium text-accent-600 transition hover:gap-3 dark:text-accent-400"
    >
      See more on GitHub <Icon name="arrow" class="h-4 w-4" />
    </a>
  </div>
</section>
