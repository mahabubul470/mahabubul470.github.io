---
import { experience } from "../data/experience";
import SectionHeading from "./SectionHeading.astro";
---

<section id="experience" class="border-y border-zinc-200 bg-zinc-50/60 dark:border-zinc-800 dark:bg-zinc-900/30">
  <div class="mx-auto max-w-5xl px-5 py-20 sm:px-6">
    <SectionHeading
      eyebrow="Experience"
      title="Where I've worked"
      lead="3+ years across payments, AI platforms, and computer-vision systems."
    />

    <ol class="relative border-l border-zinc-200 dark:border-zinc-800">
      {experience.map((job) => (
        <li class="reveal relative ml-6 pb-10 last:pb-0">
          <span
            class="absolute -left-[31px] top-1.5 flex h-3 w-3 items-center justify-center rounded-full border-2 border-accent-500 bg-white dark:bg-zinc-950"
          ></span>
          <div class="flex flex-col gap-1 sm:flex-row sm:items-baseline sm:justify-between">
            <h3 class="text-base font-semibold text-zinc-900 dark:text-zinc-100">
              {job.role}
              <span class="text-accent-600 dark:text-accent-400"> · {job.company}</span>
            </h3>
            <span class="font-mono text-xs text-zinc-500 dark:text-zinc-500">{job.period}</span>
          </div>
          <p class="mt-0.5 text-xs text-zinc-500 dark:text-zinc-500">{job.location}</p>
          <ul class="mt-3 space-y-2">
            {job.points.map((pt) => (
              <li class="flex gap-2.5 text-sm leading-relaxed text-zinc-600 dark:text-zinc-400">
                <span class="mt-2 h-1 w-1 shrink-0 rounded-full bg-zinc-400 dark:bg-zinc-600"></span>
                {pt}
              </li>
            ))}
          </ul>
          <ul class="mt-3 flex flex-wrap gap-1.5">
            {job.tech.map((t) => (
              <li class="rounded-md bg-zinc-100 px-2 py-0.5 font-mono text-xs text-zinc-600 dark:bg-zinc-800 dark:text-zinc-400">
                {t}
              </li>
            ))}
          </ul>
        </li>
      ))}
    </ol>
  </div>
</section>
