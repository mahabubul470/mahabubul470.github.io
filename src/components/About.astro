---
import { skills, achievements } from "../data/skills";
import SectionHeading from "./SectionHeading.astro";
---

<section id="about" class="border-t border-zinc-200 bg-zinc-50/60 dark:border-zinc-800 dark:bg-zinc-900/30">
  <div class="mx-auto max-w-5xl px-5 py-20 sm:px-6">
    <SectionHeading eyebrow="About" title="A bit more about me" />

    <div class="grid gap-10 md:grid-cols-[1.1fr_1fr]">
      <div class="reveal space-y-4 text-sm leading-relaxed text-zinc-600 dark:text-zinc-400">
        <p>
          I'm a software engineer based in Dhaka who likes the hard parts of backend work —
          distributed data, failover, settlement logic, observability — and shipping them to
          production. Most recently I architected a Bangladesh Bank–compliant payment gateway from
          scratch.
        </p>
        <p>
          I came up through computer-vision research (cattle biometrics, semantic segmentation,
          autonomous rover navigation) and still build in that space, which is why my work spans
          fintech, AI platforms, and IoT. On the side I build open-source systems tools like
          LiveSQL, Canopy Cloud, and an AI-native VCS in Rust.
        </p>

        <div class="rounded-2xl border border-zinc-200 bg-white p-5 dark:border-zinc-800 dark:bg-zinc-900/40">
          <h3 class="font-mono text-xs font-medium uppercase tracking-widest text-accent-600 dark:text-accent-400">
            Education
          </h3>
          <p class="mt-2 text-sm font-semibold text-zinc-900 dark:text-zinc-100">
            B.Sc. in Computer Science & Engineering
          </p>
          <p class="text-sm text-zinc-600 dark:text-zinc-400">
            American International University-Bangladesh · 2018–2023 · CGPA 3.59/4.0
          </p>
        </div>

        <div>
          <h3 class="mb-3 font-mono text-xs font-medium uppercase tracking-widest text-accent-600 dark:text-accent-400">
            Achievements
          </h3>
          <ul class="space-y-2">
            {achievements.map((a) => (
              <li class="flex gap-2.5 text-sm leading-relaxed text-zinc-600 dark:text-zinc-400">
                <span class="mt-2 h-1 w-1 shrink-0 rounded-full bg-accent-500"></span>
                {a}
              </li>
            ))}
          </ul>
        </div>
      </div>

      <div class="reveal">
        <h3 class="mb-4 font-mono text-xs font-medium uppercase tracking-widest text-accent-600 dark:text-accent-400">
          Tech I work with
        </h3>
        <div class="space-y-4">
          {skills.map((g) => (
            <div>
              <p class="mb-2 text-xs font-medium text-zinc-500 dark:text-zinc-500">{g.label}</p>
              <ul class="flex flex-wrap gap-1.5">
                {g.items.map((it) => (
                  <li class="rounded-md border border-zinc-200 bg-white px-2.5 py-1 font-mono text-xs text-zinc-700 dark:border-zinc-800 dark:bg-zinc-900 dark:text-zinc-300">
                    {it}
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
