---
import { site } from "../data/site";
import Icon from "./Icon.astro";

const socials = [
  { name: "github", href: site.socials.github, label: "GitHub" },
  { name: "linkedin", href: site.socials.linkedin, label: "LinkedIn" },
  { name: "scholar", href: site.socials.scholar, label: "Google Scholar" },
  { name: "leetcode", href: site.socials.leetcode, label: "LeetCode" },
  { name: "codeforces", href: site.socials.codeforces, label: "Codeforces" },
] as const;
---

<section id="top" class="relative overflow-hidden">
  <!-- soft accent glow -->
  <div
    aria-hidden="true"
    class="pointer-events-none absolute -top-40 left-1/2 h-[36rem] w-[36rem] -translate-x-1/2 rounded-full bg-accent-500/10 blur-3xl dark:bg-accent-500/15"
  >
  </div>

  <div class="mx-auto max-w-5xl px-5 pb-16 pt-28 sm:px-6 sm:pt-36">
    <div class="grid items-center gap-10 md:grid-cols-[1.4fr_1fr]">
      <!-- text -->
      <div class="reveal">
        <p
          class="mb-4 inline-flex items-center gap-2 rounded-full border border-zinc-200 px-3 py-1 font-mono text-xs text-zinc-500 dark:border-zinc-800 dark:text-zinc-400"
        >
          <span class="h-1.5 w-1.5 rounded-full bg-green-500"></span>
          Open to backend & ML engineering roles
        </p>
        <h1
          class="text-4xl font-bold tracking-tight text-zinc-900 sm:text-5xl dark:text-zinc-50"
        >
          {site.name}
        </h1>
        <p class="mt-3 text-lg font-medium text-accent-600 dark:text-accent-400">
          {site.role} · fintech · AI · IoT
        </p>
        <p class="mt-5 max-w-xl text-pretty text-base leading-relaxed text-zinc-600 dark:text-zinc-400">
          {site.tagline}
        </p>

        <div class="mt-7 flex flex-wrap items-center gap-3">
          <a
            href={`mailto:${site.email}`}
            class="inline-flex items-center gap-2 rounded-lg bg-accent-600 px-4 py-2.5 text-sm font-medium text-white transition hover:bg-accent-700"
          >
            <Icon name="mail" class="h-4 w-4" /> Get in touch
          </a>
          <a
            href={site.resumes.professional}
            target="_blank"
            rel="noopener"
            class="inline-flex items-center gap-2 rounded-lg border border-zinc-300 px-4 py-2.5 text-sm font-medium text-zinc-700 transition hover:border-accent-500 hover:text-accent-600 dark:border-zinc-700 dark:text-zinc-300 dark:hover:border-accent-400 dark:hover:text-accent-400"
          >
            <Icon name="download" class="h-4 w-4" /> Résumé
          </a>
          <a
            href={site.resumes.academic}
            target="_blank"
            rel="noopener"
            class="inline-flex items-center gap-2 rounded-lg border border-zinc-300 px-4 py-2.5 text-sm font-medium text-zinc-700 transition hover:border-accent-500 hover:text-accent-600 dark:border-zinc-700 dark:text-zinc-300 dark:hover:border-accent-400 dark:hover:text-accent-400"
          >
            <Icon name="download" class="h-4 w-4" /> Academic CV
          </a>
        </div>

        <div class="mt-7 flex items-center gap-1">
          {socials.map((s) => (
            <a
              href={s.href}
              target="_blank"
              rel="noopener"
              aria-label={s.label}
              title={s.label}
              class="inline-flex h-9 w-9 items-center justify-center rounded-lg text-zinc-500 transition hover:bg-zinc-100 hover:text-accent-600 dark:text-zinc-400 dark:hover:bg-zinc-900 dark:hover:text-accent-400"
            >
              <Icon name={s.name} class="h-5 w-5" />
            </a>
          ))}
          <span class="ml-2 inline-flex items-center gap-1.5 text-sm text-zinc-500 dark:text-zinc-500">
            <Icon name="location" class="h-4 w-4" /> {site.location}
          </span>
        </div>
      </div>

      <!-- photo -->
      <div class="reveal order-first md:order-last">
        <div class="relative mx-auto w-56 sm:w-64 md:w-full md:max-w-xs">
          <div
            aria-hidden="true"
            class="absolute -inset-3 -rotate-3 rounded-3xl bg-gradient-to-br from-accent-500/30 to-accent-700/10"
          >
          </div>
          <picture>
            <source srcset="/profile.webp" type="image/webp" />
            <img
              src="/profile.jpg"
              alt={`Portrait of ${site.name}`}
              width="800"
              height="800"
              loading="eager"
              fetchpriority="high"
              class="relative aspect-square w-full rounded-3xl object-cover shadow-xl ring-1 ring-zinc-900/10 dark:ring-white/10"
            />
          </picture>
        </div>
      </div>
    </div>
  </div>
</section>
